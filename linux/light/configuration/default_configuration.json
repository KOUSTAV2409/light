{
  "theme": "raycast",
  "background_color": "#1C1C1E",
  "text_color": "#F5F5F7",
  "selected_item_background_color": "#FF6363",
  "answer_background_color": "#252528",
  "answer_selected_background_color": "#3A3A3C",
  "maximum_width": 680,
  "maximum_height": 560,
  "search_bar_height": 58,
  "result_item_height": 52,
  "result_item_limit": 25,
  "search_paths": ["~"],
  "blocked_paths": [
    "/proc",
    "/sys",
    "/dev",
    "/run",
    "/usr/lib",
    "/usr/share"
  ],
  "activation_hotkey": "alt+space",
  "default_search_engine": "google",
  "show_icons": true,
  "show_keyboard_hints": true,
  "openai_enabled": false,
  "openai_model": "gpt-4o",
  "openai_web_search": true,
  "clipboard_history_enabled": false,
  "clipboard_history_limit": 50,
  "extensions_enabled": true,
  "usage_metrics_enabled": false
}
